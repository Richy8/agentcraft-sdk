# Cloud providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...
COHERE_API_KEY=...
XAI_API_KEY=...
CEREBRAS_API_KEY=...
DEEPSEEK_API_KEY=...

# AWS Bedrock
# Alternative: configure an IAM role or use ~/.aws/credentials
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# Google Vertex AI
# Alternative to GOOGLE_API_KEY when using GCP project auth
GOOGLE_CLOUD_PROJECT=my-project-id

# Native adapters and MCP wrappers
GITHUB_TOKEN=ghp_...
DATABASE_URL=postgres://readonly:password@localhost:5432/app
SLACK_BOT_TOKEN=xoxb-...
SLACK_TEAM_ID=T00000000
TAVILY_API_KEY=tvly-...
FIRECRAWL_API_KEY=fc-...
APIFY_TOKEN=apify_api_...
ELEVENLABS_API_KEY=...

# Local providers
OLLAMA_BASE_URL=http://localhost:11434/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Integration test gate
# Set to 'true' to enable live API tests (incurs API costs)
INTEGRATION_TESTS=false

# Optional low-cost live integration model overrides
AGENTCRAFT_LIVE_OPENAI_MODEL=gpt-4o-mini
AGENTCRAFT_LIVE_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
AGENTCRAFT_LIVE_GEMINI_MODEL=gemini-2.5-flash
AGENTCRAFT_LIVE_MAX_TOKENS=64
AGENTCRAFT_LIVE_APIFY_DATASET_ID=

# Read-only live adapter/MCP fixtures
AGENTCRAFT_LIVE_GITHUB_REPO=octocat/Hello-World
AGENTCRAFT_LIVE_PUBLIC_URL=https://vitepress.dev/
AGENTCRAFT_LIVE_FETCH_URL=https://vitepress.dev/
AGENTCRAFT_LIVE_FIRECRAWL_URL=https://vitepress.dev/
AGENTCRAFT_LIVE_TAVILY_QUERY=vitepress documentation
AGENTCRAFT_LIVE_FILESYSTEM_PATH=/private/tmp/agentcraft-live-fixture
AGENTCRAFT_LIVE_MCP_FILESYSTEM_PATH=/private/tmp/agentcraft-live-fixture

# Public Basic Auth fixture, safe for testing authenticated access behavior.
AGENTCRAFT_LIVE_AUTH_URL=https://httpbin.org/basic-auth/agentcraft/smoke
AGENTCRAFT_LIVE_AUTH_USERNAME=agentcraft
AGENTCRAFT_LIVE_AUTH_PASSWORD=smoke
AGENTCRAFT_LIVE_AUTH_DOMAIN=httpbin.org
AGENTCRAFT_LIVE_PLAYWRIGHT_AUTH_URL=https://agentcraft:smoke@httpbin.org/basic-auth/agentcraft/smoke

# Write-capable live tests stay disabled unless explicitly enabled.
AGENTCRAFT_LIVE_ALLOW_WRITES=false
